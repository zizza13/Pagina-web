---
// Contact.astro
const phoneNumber = "5000 000 0000";
const numericPhone = phoneNumber.replace(/[^0-9]/g, "");
const address = "123 Cooling Lane, Weather City, TX 75000";
const email = "service@prohvac.com";
---

<section id="contact" class="py-20 bg-gradient-to-b from-white to-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-blue-600 font-bold tracking-wide uppercase text-sm">
        Contact Us
      </h2>
      <p
        class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-slate-900 sm:text-4xl"
      >
        Ready for Better Air?
      </p>
      <p class="mt-4 text-lg text-slate-500">
        Call us immediately for emergencies or fill out the form below to
        schedule a routine visit.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8">
      <!-- Contact Info Box -->
      <div
        class="bg-blue-600 rounded-2xl p-8 lg:p-12 text-white shadow-xl flex flex-col justify-between"
      >
        <div>
          <h3 class="text-2xl font-bold mb-6">Contact Information</h3>
          <p class="text-blue-100 mb-8 leading-relaxed">
            Our support team is available 24/7 to help you with any HVAC
            emergencies. Do not hesitate to call!
          </p>

          <div class="space-y-6">
            <div class="flex items-start">
              <svg
                class="h-6 w-6 text-blue-200 mt-1 mr-4 flex-shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path></svg
              >
              <div>
                <p class="font-medium text-blue-100">Phone</p>
                <a
                  href={`tel:${numericPhone}`}
                  class="text-xl font-bold hover:text-white transition-colors"
                  >{phoneNumber}</a
                >
              </div>
            </div>

            <div class="flex items-start">
              <svg
                class="h-6 w-6 text-blue-200 mt-1 mr-4 flex-shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
              >
              <div>
                <p class="font-medium text-blue-100">Service Area</p>
                <p class="text-lg">{address}</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg
                class="h-6 w-6 text-blue-200 mt-1 mr-4 flex-shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path></svg
              >
              <div>
                <p class="font-medium text-blue-100">Email</p>
                <a
                  href={`mailto:${email}`}
                  class="text-lg hover:text-white transition-colors">{email}</a
                >
              </div>
            </div>
          </div>
        </div>

        <div class="mt-12 flex space-x-4">
          <!-- Social Icons or additional badges could go here -->
          <div class="bg-blue-700 p-4 rounded-xl font-bold text-center w-full">
            Licensed & Insured #HVAC-708908
          </div>
        </div>
      </div>

      <!-- Purely Visual Form -->
      <div
        class="bg-white rounded-2xl p-8 lg:p-10 shadow-lg border border-gray-100"
      >
        <h3 class="text-2xl font-bold text-slate-900 mb-6">Schedule Service</h3>

        <form class="space-y-6" onsubmit="event.preventDefault();">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label
                for="first-name"
                class="block text-sm font-medium text-slate-700"
                >First name</label
              >
              <input
                type="text"
                id="first-name"
                class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-3 border bg-slate-50"
                placeholder="John"
              />
            </div>
            <div>
              <label
                for="last-name"
                class="block text-sm font-medium text-slate-700"
                >Last name</label
              >
              <input
                type="text"
                id="last-name"
                class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-3 border bg-slate-50"
                placeholder="Doe"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700"
              >Phone</label
            >
            <input
              type="tel"
              id="phone"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-3 border bg-slate-50"
              placeholder="(555) 000-0000"
            />
          </div>

          <div>
            <label
              for="service-type"
              class="block text-sm font-medium text-slate-700"
              >Service Required</label
            >
            <select
              id="service-type"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-3 border bg-slate-50 text-slate-700"
            >
              <option>Emergency Repair</option>
              <option>New Installation</option>
              <option>Routine Maintenance</option>
              <option>Other Estimate</option>
            </select>
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-slate-700"
              >How can we help?</label
            >
            <textarea
              id="message"
              rows="4"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-4 py-3 border bg-slate-50"
              placeholder="Tell us about the issue..."></textarea>
          </div>

          <div>
            <button
              type="submit"
              class="w-full flex justify-center py-3.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
            >
              Send Request
            </button>
            <p class="mt-3 text-center text-xs text-slate-500">
              This form is for demonstration purposes.
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
