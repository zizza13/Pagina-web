---
// Hero.astro
const phoneNumber = "562-244-7119";
const numericPhone = phoneNumber.replace(/[^0-9]/g, '');
---

<section id="home" class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <!-- Background Pattern or Image Placeholder -->
  <div class="absolute inset-0 z-0 bg-blue-50">
    <!-- Replace this div with an actual background image using: style="background-image: url('my-image.jpg'); background-size: cover; background-position: center;" -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-100 to-white opacity-90"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center lg:text-left flex flex-col lg:flex-row items-center">
    
    <div class="w-full lg:w-1/2 lg:pr-12">
      <h1 class="text-4xl tracking-tight font-extrabold text-slate-900 sm:text-5xl md:text-6xl text-balance">
        <span class="block">Reliable HVAC Services</span>
        <span class="block text-blue-600 mt-2">When You Need Them Most</span>
      </h1>
      <p class="mt-4 max-w-md mx-auto lg:mx-0 text-base text-slate-600 sm:text-lg md:mt-6 md:text-xl text-balance">
        Fast, professional air conditioning repair, installation, and maintenance. We keep your home comfortable all year round.
      </p>
      
      <div class="mt-8 sm:flex sm:justify-center lg:justify-start gap-4">
        <div class="rounded-full shadow-lg">
          <a href={`tel:${numericPhone}`} class="w-full flex items-center justify-center px-8 py-3.5 border border-transparent text-base font-bold rounded-full text-white bg-blue-600 hover:bg-blue-700 md:py-4 md:text-lg transition-transform hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {phoneNumber}
          </a>
        </div>
        <div class="mt-3 sm:mt-0">
          <a href="#services" class="w-full flex items-center justify-center px-8 py-3.5 border border-slate-300 text-base font-semibold rounded-full text-slate-700 bg-white hover:bg-slate-50 md:py-4 md:text-lg transition-colors">
            Our Services
          </a>
        </div>
      </div>
      
      <!-- Trust badges / mini info -->
      <div class="mt-8 flex items-center justify-center lg:justify-start space-x-6 text-sm font-medium text-slate-500">
        <div class="flex items-center">
          <svg class="h-5 w-5 text-green-500 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          24/7 Emergency
        </div>
        <div class="flex items-center">
          <svg class="h-5 w-5 text-green-500 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Licensed & Insured
        </div>
      </div>
    </div>

    <!-- Right Side Image (Hidden on small mobile, visible on md+) -->
    <div class="hidden lg:block w-full lg:w-1/2 mt-12 lg:mt-0 relative">
      <div class="aspect-w-4 aspect-h-3 rounded-2xl overflow-hidden shadow-2xl">
        <!-- Replace src with an actual hero image -->
        <div class="w-full h-96 bg-slate-200 flex items-center justify-center">
          <span class="text-slate-400">AC Unit Image Placeholder</span>
        </div>
      </div>
      
      <!-- Decorative element -->
      <!--
      <div class="absolute -bottom-6 -left-6 bg-white p-4 rounded-xl shadow-xl flex items-center space-x-4">
        <div class="bg-blue-100 p-3 rounded-full">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path></svg>
        </div>
        <div>
          
          <p class="text-xs text-slate-500 font-medium">Customer Satisfaction</p>
          <p class="text-lg font-bold text-slate-800">5.0 / 5.0</p>
           -->
        </div>
      </div>
    </div>

  </div>
</section>
