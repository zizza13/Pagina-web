---
// Services.astro
const services = [
  {
    title: "AC Installation",
    description: "Expert installation of energy-efficient air conditioning systems tailored to your home's unique needs.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`
  },
  {
    title: "AC Repair",
    description: "Fast and reliable repair services to get your AC back up and running, available 24/7 for emergencies.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`
  },
  {
    title: "Maintenance",
    description: "Regular tune-ups to extend the life of your equipment, improve air quality, and lower energy bills.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`
  },
  {
    title: "Residential HVAC",
    description: "Complete heating and cooling solutions for homes, ensuring year-round comfort and energy efficiency.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`
  },
  {
    title: "Commercial HVAC",
    description: "Industrial-grade HVAC systems for businesses, designed for reliability and optimal performance in large spaces.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`
  },
  {
    title: "Ductwork / Ventilation",
    description: "Professional ductwork installation and repair to ensure proper airflow and indoor air quality throughout your property.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
  }
];
---

<section id="services" class="fade-in-section py-20 relative overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-blue-600 font-bold tracking-wide uppercase text-sm">Our Work</h2>
      <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        Professional HVAC Services
      </p>
      <p class="mt-4 max-w-2xl text-lg text-slate-500 mx-auto">
        We offer a comprehensive range of heating and cooling services to keep you comfortable through every season.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service, index) => (
        <div class="service-card bg-white rounded-2xl p-4 sm:p-5 shadow-sm hover:shadow-xl hover:scale-105 hover:ring-2 hover:ring-blue-500/30 transition-all duration-300 border border-gray-100 flex flex-col h-full cursor-pointer" data-index={index}>
          <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-base sm:text-lg font-bold text-slate-900 flex-grow">{service.title}</h3>
            <svg class="w-5 h-5 text-slate-400 sm:hidden transition-transform duration-300 chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          <div class="service-content hidden sm:block">
            <p class="text-slate-600 flex-grow leading-relaxed text-sm">
              {service.description}
            </p>
            <div class="mt-3 sm:mt-4 pt-3 sm:pt-4 border-t border-gray-100">
              <a href="#contact" class="text-blue-600 font-semibold hover:text-blue-800 transition-colors inline-flex items-center text-sm">
                Request Service
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  // Accordion behavior for mobile
  const serviceCards = document.querySelectorAll('.service-card');
  let openCard: HTMLElement | null = null;

  serviceCards.forEach(card => {
    card.addEventListener('click', () => {
      const content = card.querySelector('.service-content');
      const chevron = card.querySelector('.chevron-icon');
      
      // Only run on mobile (when chevron is visible)
      if (!chevron || window.getComputedStyle(chevron).display === 'none') return;

      if (openCard && openCard !== card) {
        // Close the previously open card
        const prevContent = openCard.querySelector('.service-content');
        const prevChevron = openCard.querySelector('.chevron-icon');
        prevContent?.classList.add('hidden');
        if (prevChevron && prevChevron instanceof HTMLElement) {
          prevChevron.style.transform = 'rotate(0deg)';
        }
      }

      // Toggle current card
      if (content && content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        if (chevron instanceof HTMLElement) {
          chevron.style.transform = 'rotate(180deg)';
        }
        openCard = card as HTMLElement;
      } else if (content) {
        content.classList.add('hidden');
        if (chevron instanceof HTMLElement) {
          chevron.style.transform = 'rotate(0deg)';
        }
        openCard = null;
      }
    });
  });
</script>
