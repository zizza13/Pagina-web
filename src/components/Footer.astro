---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 border-t border-slate-800">
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:py-16 lg:px-8">
    <div class="md:flex md:items-center md:justify-between">
      <div class="flex justify-center md:justify-start items-center space-x-2 pb-4 md:pb-0">
        <img src="/logo.png" alt="Air Quality Systems Logo" class="h-12 w-auto" />
        <span class="text-xl font-bold text-white tracking-wider">AIR QUALITY SYSTEMS</span>
      </div>
      
      <div class="flex justify-center space-x-6 md:order-2">
        <a href="#home" class="text-slate-400 hover:text-white transition-colors">
          <span class="sr-only">Home</span>
          Home
        </a>
        <a href="#services" class="text-slate-400 hover:text-white transition-colors">
          <span class="sr-only">Services</span>
          Services
        </a>
        <a href="#about" class="text-slate-400 hover:text-white transition-colors">
          <span class="sr-only">About</span>
          About
        </a>
        <a href="#contact" class="text-slate-400 hover:text-white transition-colors">
          <span class="sr-only">Contact</span>
          Contact
        </a>
      </div>
    </div>
    <div class="mt-8 border-t border-slate-800 pt-8 md:flex md:items-center md:justify-between">
      <p class="text-base text-slate-400 md:order-1 flex justify-center text-center">
        &copy; {year} ProHVAC Services. All rights reserved.
      </p>
      <p class="text-sm text-slate-500 mt-4 md:mt-0 md:order-3 text-center">
        Designed for High Conversion
      </p>
    </div>
  </div>
</footer>
