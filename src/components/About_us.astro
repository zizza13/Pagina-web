---
// About_us.astro
---

<section id="about_us" class="fade-in-section py-20 relative overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
      
      <!-- Text Side -->
      <div class="mb-12 lg:mb-0">
        <h2 class="text-base text-blue-600 font-semibold tracking-wide uppercase">About Us</h2>
        <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Your Local Climate Control Experts
        </p>
        <p class="mt-4 text-lg text-slate-600 leading-relaxed mb-6">
          With over 15 years of experience in the HVAC industry, our team is dedicated to providing top-notch air conditioning and heating services to our community. We believe in honest pricing, quality workmanship, and treating every home as if it were our own.
        </p>
        
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-10 w-10 rounded-md bg-blue-600 text-white">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
            </div>
            <div class="ml-4">
              <h3 class="text-lg leading-6 font-medium text-slate-900">Certified Technicians</h3>
              <p class="mt-1 text-base text-slate-500">All our staff undergo rigorous training and hold up-to-date industry certifications.</p>
            </div>
          </div>

          <div class="flex items-start pb-4">
            <div class="flex-shrink-0">
              <div class="flex items-center justify-center h-10 w-10 rounded-md bg-blue-600 text-white">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
            </div>
            <div class="ml-4">
              <h3 class="text-lg leading-6 font-medium text-slate-900">Punctual & Reliable</h3>
              <p class="mt-1 text-base text-slate-500">We respect your time. When you schedule an appointment, we arrive promptly and fully equipped.</p>
            </div>
          </div>
        </div>
        
        <div class="mt-8">
          <a href="#contact" class="inline-flex px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-slate-800 hover:bg-slate-900 transition-colors">
            Get a Free Estimate
          </a>
        </div>
      </div>
      
      <!-- Image Side Placeholder -->
      <div class="relative">
        <!-- Main Image Placeholder (E.g., A technician smiling) -->
        <img src="/about-us.png" alt="Technician" class="rounded-2xl shadow-xl w-full object-cover" />

        <!-- Floating Badge -->
        <div class="absolute -bottom-6 -right-6 lg:-left-6 lg:right-auto bg-blue-600 rounded-xl p-6 shadow-xl text-white transform hover:scale-105 transition-transform">
          <p class="text-4xl font-extrabold">30+</p>
          <p class="text-blue-100 font-medium mt-1">Years Experience</p>
        </div>
      </div>

    </div>
  </div>
</section>
